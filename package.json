{
  "name": "umk-master-app",
  "version": "1.0.0",
  "description": "УМК Мастера производственного обучения",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win32": "electron-builder --win --ia32",
    "dist:win64": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.umk.master",
    "productName": "УМК Мастер",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^21.4.4",
    "electron-builder": "^21.2.0",
    "pkg": "^5.8.1"
  }
}
